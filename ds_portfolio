<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stefanie Si — Data Scientist</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --ink:#3d2b2b;
  --paper:#F9F1F0;
  --accent:#c27a6e;
  --accent2:#F79489;
  --muted:#9a7e7e;
  --card:#ffffff;
  --border:#f0ddd9;
  --grad1:#d4908a;
  --grad2:#F8AFA6;
  --grad3:#FADCD9;
}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:'DM Sans',sans-serif;background:var(--paper);color:var(--ink);overflow-x:hidden;line-height:1.6}

/* ===== HERO ===== */
.hero{
  min-height:100vh;
  background:linear-gradient(160deg,var(--grad1) 0%,var(--grad2) 40%,var(--grad3) 100%);
  display:flex;align-items:center;justify-content:center;
  position:relative;overflow:hidden;
}
.hero::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse 600px 400px at 15% 80%,rgba(247,148,137,0.3),transparent),
    radial-gradient(ellipse 500px 500px at 85% 20%,rgba(250,220,217,0.3),transparent);
}
.hero-grid{
  position:absolute;inset:0;
  background-image:
    linear-gradient(rgba(61,43,43,.04) 1px,transparent 1px),
    linear-gradient(90deg,rgba(61,43,43,.04) 1px,transparent 1px);
  background-size:60px 60px;
}
.hero-content{position:relative;z-index:2;text-align:center;padding:2rem;max-width:900px}
.hero-label{
  font-family:'JetBrains Mono',monospace;font-size:.75rem;letter-spacing:4px;text-transform:uppercase;
  color:#5a3a3a;margin-bottom:1.5rem;
  opacity:0;animation:fadeUp .8s .3s forwards;
}
.hero h1{
  font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3.5rem);
  color:var(--ink);font-weight:700;line-height:1.15;margin-bottom:1rem;
  opacity:0;animation:fadeUp .8s .5s forwards;
}
.hero h1 em{font-style:italic;color:var(--accent2)}
.hero-sub{
  font-size:clamp(1rem,2vw,1.25rem);color:rgba(61,43,43,.65);
  max-width:600px;margin:0 auto 2.5rem;font-weight:300;
  opacity:0;animation:fadeUp .8s .7s forwards;
}
.hero-tags{
  display:flex;flex-wrap:wrap;gap:.5rem;justify-content:center;
  opacity:0;animation:fadeUp .8s .9s forwards;
}
.hero-tags span{
  font-family:'JetBrains Mono',monospace;font-size:.7rem;
  padding:.4rem .9rem;border:1px solid rgba(255,255,255,.15);
  border-radius:100px;color:rgba(255,255,255,.6);
  background:rgba(255,255,255,.04);backdrop-filter:blur(4px);
  transition:all .3s;
}
.hero-tags span:hover{border-color:var(--accent2);color:var(--accent2)}
.hero-cta{
  margin-top:2.5rem;display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;
  opacity:0;animation:fadeUp .8s .9s forwards;
}
.hero-cta a{
  font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:600;
  padding:.8rem 2rem;border-radius:100px;text-decoration:none;
  transition:all .3s;letter-spacing:.5px;
}
.btn-primary{background:var(--ink);color:#fff}
.btn-primary:hover{background:#5a3a3a;transform:translateY(-2px);box-shadow:0 8px 25px rgba(61,43,43,.2)}
.btn-outline{border:1.5px solid rgba(61,43,43,.3);color:var(--ink)}
.btn-outline:hover{border-color:var(--ink);background:rgba(61,43,43,.06)}
.scroll-hint{
  position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);
  color:rgba(61,43,43,.3);font-size:.7rem;letter-spacing:3px;
  font-family:'JetBrains Mono',monospace;text-transform:uppercase;
  animation:pulse 2s infinite;
}

/* ===== NAV ===== */
.nav{
  position:fixed;top:0;left:0;right:0;z-index:100;
  padding:1rem 2rem;
  background:rgba(60,40,40,.85);backdrop-filter:blur(12px);
  display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid rgba(255,255,255,.06);
  transform:translateY(-100%);transition:transform .4s;
}
.nav.visible{transform:translateY(0)}
.nav-logo{font-family:'Playfair Display',serif;font-size:1.1rem;color:#fff;font-weight:700}
.nav-links{display:flex;gap:1.5rem}
.nav-links a{
  font-size:.8rem;color:rgba(255,255,255,.6);text-decoration:none;
  font-weight:500;letter-spacing:.5px;transition:color .3s;
}
.nav-links a:hover{color:var(--accent2)}

/* ===== SECTIONS ===== */
section{padding:6rem 2rem}
.container{max-width:1100px;margin:0 auto}
.section-label{
  font-family:'JetBrains Mono',monospace;font-size:.7rem;
  letter-spacing:4px;text-transform:uppercase;color:var(--accent);
  margin-bottom:.5rem;
}
.section-title{
  font-family:'Playfair Display',serif;font-size:clamp(2rem,4vw,3rem);
  font-weight:700;margin-bottom:1rem;line-height:1.15;
}
.section-desc{color:var(--muted);max-width:600px;margin-bottom:3rem;font-weight:300}

/* ===== ABOUT ===== */
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start}
.about-text p{margin-bottom:1.2rem;color:#374151;line-height:1.8}
.about-skills{display:flex;flex-direction:column;gap:1.2rem}
.skill-card-mini{
  background:var(--card);border:1px solid var(--border);border-radius:12px;
  padding:1.2rem 1.5rem;transition:all .3s;
}
.skill-card-mini:hover{box-shadow:0 8px 20px rgba(0,0,0,.05);border-color:var(--accent)}
.skill-card-mini h4{font-size:.85rem;font-weight:600;color:var(--ink);margin-bottom:.6rem}
.skill-list{display:flex;flex-wrap:wrap;gap:.4rem}
.skill-list span{
  font-family:'JetBrains Mono',monospace;font-size:.7rem;
  padding:.3rem .7rem;background:rgba(194,122,110,.08);
  border-radius:6px;color:var(--accent);font-weight:500;
}

/* ===== CONTACT POPUP ===== */
.contact-fab{
  position:fixed;bottom:2rem;right:2rem;z-index:200;
}
.contact-fab-btn{
  width:56px;height:56px;border-radius:50%;border:none;
  background:var(--ink);color:#fff;font-size:1.4rem;
  cursor:pointer;box-shadow:0 6px 20px rgba(0,0,0,.2);
  transition:all .3s;display:flex;align-items:center;justify-content:center;
}
.contact-fab-btn:hover{transform:scale(1.08);box-shadow:0 8px 28px rgba(0,0,0,.3)}
.contact-popup{
  position:absolute;bottom:70px;right:0;
  width:320px;background:#fff;border-radius:16px;
  box-shadow:0 20px 60px rgba(0,0,0,.15);border:1px solid var(--border);
  padding:1.8rem;
  opacity:0;visibility:hidden;transform:translateY(10px) scale(.95);
  transition:all .3s;
}
.contact-popup.open{opacity:1;visibility:visible;transform:translateY(0) scale(1)}
.contact-popup::after{
  content:'';position:absolute;bottom:-8px;right:22px;
  width:16px;height:16px;background:#fff;
  border-right:1px solid var(--border);border-bottom:1px solid var(--border);
  transform:rotate(45deg);
}
.contact-popup-title{
  font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700;
  color:var(--ink);margin-bottom:.3rem;
}
.contact-popup-desc{font-size:.8rem;color:var(--muted);margin-bottom:1.2rem;line-height:1.5}
.contact-popup-links{display:flex;flex-direction:column;gap:.6rem}
.contact-popup-link{
  display:flex;align-items:center;gap:.6rem;
  padding:.7rem 1rem;border:1px solid var(--border);
  border-radius:10px;color:var(--ink);text-decoration:none;
  font-size:.82rem;font-weight:500;transition:all .3s;
}
.contact-popup-link:hover{background:rgba(194,122,110,.06);border-color:var(--accent)}
.contact-popup-link-icon{font-size:1rem;width:1.4rem;text-align:center}

/* ===== EXPERIENCE ===== */
.exp-section{background:#fff}
.timeline{position:relative;padding-left:3rem}
.timeline::before{
  content:'';position:absolute;left:7px;top:8px;bottom:0;
  width:2px;background:linear-gradient(var(--accent),var(--accent2));
}
.timeline-item{
  position:relative;margin-bottom:3rem;
}
.timeline-dot{
  position:absolute;left:-3rem;top:8px;
  width:16px;height:16px;border-radius:50%;
  background:var(--paper);border:3px solid var(--accent);
  transition:all .3s;
}
.timeline-item:hover .timeline-dot{background:var(--accent);box-shadow:0 0 0 6px rgba(194,122,110,.15)}
.timeline-header{display:flex;align-items:baseline;justify-content:space-between;flex-wrap:wrap;gap:.5rem;margin-bottom:.3rem}
.timeline-company{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700}
.timeline-date{font-family:'JetBrains Mono',monospace;font-size:.75rem;color:var(--muted)}
.timeline-role{font-weight:600;color:var(--accent);margin-bottom:.8rem;font-size:.95rem}
.timeline-bullets{list-style:none;display:flex;flex-direction:column;gap:.6rem}
.timeline-bullets li{
  position:relative;padding-left:1.2rem;color:#374151;font-size:.9rem;line-height:1.7;
}
.timeline-bullets li::before{
  content:'';position:absolute;left:0;top:.65em;width:5px;height:5px;border-radius:50%;background:var(--accent2);
}


/* ===== PROJECT ===== */
.project-section{background:#fff}
.project-card{
  display:grid;grid-template-columns:1fr 1fr;gap:3rem;
  background:linear-gradient(135deg,var(--grad1),var(--grad2));
  border-radius:20px;padding:3rem;color:#fff;
  position:relative;overflow:hidden;
  transition:transform .4s;
}
.project-card:hover{transform:translateY(-4px)}
.project-card::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 80% 20%,rgba(249,241,240,.15),transparent);
}
.project-info{position:relative;z-index:1}
.project-badge{
  display:inline-block;font-family:'JetBrains Mono',monospace;font-size:.65rem;
  padding:.3rem .8rem;background:rgba(255,255,255,.2);color:#fff;
  border-radius:100px;letter-spacing:2px;text-transform:uppercase;margin-bottom:1rem;
}
.project-info h3{font-family:'Playfair Display',serif;font-size:1.8rem;margin-bottom:1rem}
.project-info p{color:rgba(255,255,255,.7);font-size:.9rem;line-height:1.8;margin-bottom:1.5rem}
.project-tech{display:flex;flex-wrap:wrap;gap:.4rem;margin-bottom:1.5rem}
.project-tech span{
  font-family:'JetBrains Mono',monospace;font-size:.65rem;
  padding:.3rem .6rem;border:1px solid rgba(255,255,255,.2);
  border-radius:6px;color:rgba(255,255,255,.7);
}
.project-link{
  display:inline-flex;align-items:center;gap:.5rem;
  color:#fff;text-decoration:none;font-weight:600;font-size:.9rem;
  transition:gap .3s;
}
.project-link:hover{gap:.8rem}
.project-visual{
  position:relative;z-index:1;display:flex;align-items:center;justify-content:center;
}
.project-mockup{
  width:100%;aspect-ratio:4/3;border-radius:12px;overflow:hidden;
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);
  backdrop-filter:blur(8px);
  display:flex;flex-direction:column;
}
.mockup-bar{
  display:flex;gap:6px;padding:12px 16px;background:rgba(0,0,0,.2);
}
.mockup-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.2)}
.mockup-content{flex:1;padding:1rem;display:flex;flex-direction:column;gap:.6rem}
.mockup-line{height:8px;border-radius:4px;background:rgba(255,255,255,.08)}
.mockup-line.short{width:60%}
.mockup-line.med{width:80%}
.mockup-chart{
  flex:1;display:flex;align-items:flex-end;gap:6px;padding-top:.5rem;
}
.mockup-bar-v{
  flex:1;border-radius:4px 4px 0 0;
  background:linear-gradient(to top,rgba(194,122,110,.4),rgba(250,220,217,.5));
  animation:barGrow 1.5s ease forwards;
}

/* ===== EDUCATION ===== */
.edu-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem}
.edu-card{
  background:var(--card);border:1px solid var(--border);border-radius:16px;
  padding:2rem;transition:all .3s;
}
.edu-card:hover{transform:translateY(-3px);box-shadow:0 12px 30px rgba(0,0,0,.06)}
.edu-degree{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:700;margin-bottom:.3rem}
.edu-school{color:var(--accent);font-weight:600;font-size:.9rem;margin-bottom:.2rem}
.edu-detail{font-size:.85rem;color:var(--muted)}

/* ===== FOOTER ===== */
footer{
  background:#3d2b2b;color:rgba(255,255,255,.4);
  text-align:center;padding:2rem;
  font-family:'JetBrains Mono',monospace;font-size:.7rem;letter-spacing:1px;
}

/* ===== ANIMATIONS ===== */
@keyframes fadeUp{
  from{opacity:0;transform:translateY(25px)}
  to{opacity:1;transform:translateY(0)}
}
@keyframes pulse{
  0%,100%{opacity:.35}
  50%{opacity:.7}
}
@keyframes barGrow{
  from{height:10%}
  to{height:var(--h)}
}

/* ===== RESPONSIVE ===== */
@media(max-width:768px){
  .about-grid,.edu-grid,.project-card{grid-template-columns:1fr}
  .timeline{padding-left:2rem}
  .timeline-dot{left:-2rem}
  .nav-links{display:none}
  section{padding:4rem 1.2rem}
}
</style>
</head>
<body>

<!-- Nav -->
<nav class="nav" id="nav">
  <div class="nav-logo">S. Si</div>
  <div class="nav-links">
    <a href="#about">About</a>
    <a href="#experience">Experience</a>
    <a href="#projects">Projects</a>
    <a href="#education">Education</a>
  </div>
</nav>

<!-- Hero -->
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-content">
    <div class="hero-label">Data Scientist · Analyst · Builder</div>
    <h1>Stefanie Si</h1>
    <p class="hero-sub">7+ years turning ambiguous business questions into clear, actionable data stories at Apple, Google, and beyond.</p>
    <div class="hero-cta" style="margin-top:2rem">
      <a href="#contact" class="btn-primary">Get in Touch</a>
      <a href="#experience" class="btn-outline">View My Work</a>
    </div>
  </div>
  <div class="scroll-hint">scroll</div>
</section>

<!-- About -->
<section id="about">
  <div class="container">
    <div class="about-grid">
      <div>
        <div class="section-label">About Me</div>
        <div class="section-title">Data-driven decisions,<br>human-centered stories.</div>
        <div class="about-text">
          <p>I'm a Data Scientist based in the New York / New Jersey area, specializing in causal impact analysis, ML modeling, and stakeholder communication. My career spans Big Tech (Apple, Google) and financial services (Ambac Financial), giving me a unique lens on both product analytics and quantitative finance.</p>
          <p>I thrive at the intersection of statistical rigor and business storytelling — designing experiments, building ML pipelines, and translating complex model outputs into narratives that drive product and marketing strategy.</p>
          <p>Currently, I'm also building data-powered tools through my venture, Movement Sciences Lab LLC, where I combine my analytics expertise with domain knowledge in real estate and finance.</p>
        </div>
      </div>
      <div class="about-skills">
        <div class="section-label">Toolkit</div>
        <h3 style="font-family:'Playfair Display',serif;font-size:1.4rem;margin-bottom:1.2rem">Technical Skills</h3>
        <div class="skill-card-mini">
          <h4>Programming</h4>
          <div class="skill-list">
            <span>Python</span><span>R</span><span>Scala</span><span>SAS</span><span>Spark</span>
          </div>
        </div>
        <div class="skill-card-mini">
          <h4>Database & Big Data</h4>
          <div class="skill-list">
            <span>SQL</span><span>MySQL</span><span>MS SQL Server</span><span>Google Spanner</span><span>BigQuery</span><span>Hadoop</span>
          </div>
        </div>
        <div class="skill-card-mini">
          <h4>Analytics & Modeling</h4>
          <div class="skill-list">
            <span>Gradient Boosting</span><span>Random Forest</span><span>Causal Impact</span><span>A/B Testing</span><span>PSM</span><span>Cohort Analysis</span><span>Time-series</span><span>Anomaly Detection</span>
          </div>
        </div>
        <div class="skill-card-mini">
          <h4>Visualization</h4>
          <div class="skill-list">
            <span>Tableau</span><span>Power BI</span><span>Google Data Studio</span>
          </div>
        </div>
        <div class="skill-card-mini">
          <h4>Finance & Licenses</h4>
          <div class="skill-list">
            <span>CFA Level III</span><span>FRM Level II</span><span>NJ MLO</span><span>NJ Real Estate</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Experience -->
<section id="experience" class="exp-section">
  <div class="container">
    <div class="section-label">Career</div>
    <div class="section-title">Work Experience</div>
    <div class="section-desc">A track record of influencing product and marketing strategy through data.</div>
    <div class="timeline">

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-header">
          <span class="timeline-company">Movement Sciences Lab LLC</span>
          <span class="timeline-date">Nov 2024 — Present</span>
        </div>
        <div class="timeline-role">Founder & Data Scientist · New Jersey</div>
        <ul class="timeline-bullets">
          <li>Built and deployed an interactive Mortgage Rate Tracker web app combining real-time rate data, payment calculators, rate trend prediction, and automated email alerts for home buyers and real estate professionals.</li>
        </ul>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-header">
          <span class="timeline-company">Apple</span>
          <span class="timeline-date">May 2022 — Nov 2024</span>
        </div>
        <div class="timeline-role">Data Scientist, Info Apps · New York City</div>
        <ul class="timeline-bullets">
          <li>Led Trial-to-Paid conversion analysis for Apple News across 10+ campaigns; applied ML algorithms delivering personalized recommendations that drove an 8% increase in monthly subscribers.</li>
          <li>Designed end-to-end causal impact analysis for a Books App partnership — built data infrastructure, conducted EDA, and applied propensity score matching to isolate true campaign effects.</li>
          <li>Served as primary analytics communicator for non-technical stakeholders, presenting findings twice weekly and translating complex model outputs into actionable business narratives.</li>
        </ul>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-header">
          <span class="timeline-company">Google</span>
          <span class="timeline-date">Mar 2020 — Mar 2021</span>
        </div>
        <div class="timeline-role">Data Scientist, Revenue Acceleration · Sunnyvale</div>
        <ul class="timeline-bullets">
          <li>Doubled Google Meet incremental 7-day active users through multiple A/B tests; designed and deployed automatic data pipelines for Meet adoption trends.</li>
          <li>Managed GSuite and GCP marketing pipelines integrating 2M+ accounts for targeted analysis underpinning ML-driven propensity models.</li>
          <li>Boosted LTO conversion rate by 5% leveraging ensemble ML models; created comprehensive dashboards tracking KPIs across regions and channels.</li>
        </ul>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-header">
          <span class="timeline-company">Ambac Financial</span>
          <span class="timeline-date">Mar 2019 — Mar 2020</span>
        </div>
        <div class="timeline-role">Data Scientist · New York City</div>
        <ul class="timeline-bullets">
          <li>Conducted statistical analysis on $23B portfolios, identifying and mitigating 1,000+ individual risks to preserve a stable risk rating.</li>
          <li>Built a Residential Mortgage Loan Credit Model using XGBOOST, increasing revenue 10% QoQ through optimized premium adjustments.</li>
        </ul>
      </div>

      <div class="timeline-item">
        <div class="timeline-dot"></div>
        <div class="timeline-header">
          <span class="timeline-company">Spinnaker Analytics</span>
          <span class="timeline-date">Jun 2018 — Mar 2019</span>
        </div>
        <div class="timeline-role">Data Scientist · Boston</div>
        <ul class="timeline-bullets">
          <li>Designed A/B testing campaigns using Jackknife confidence intervals, boosting buyer conversion by 150% and revenue by 28%; delivered findings via Tableau to drive strategic decisions.</li>
        </ul>
      </div>

    </div>
  </div>
</section>


<!-- Projects -->
<section id="projects" class="project-section">
  <div class="container">
    <div class="section-label">Featured Work</div>
    <div class="section-title">Projects</div>
    <div class="section-desc">Building data-powered tools that solve real problems.</div>
    <div class="project-card">
      <div class="project-info">
        <div class="project-badge">Live Project</div>
        <h3>Mortgage Rate Tracker</h3>
        <p>A full-stack web application helping home buyers and real estate professionals make data-driven financial decisions. Features real-time rate data from Mortgage News Daily & Freddie Mac PMMS, payment calculators, rate trend prediction with technical indicators, and automated email alerts.</p>
        <div class="project-tech">
          <span>Python</span><span>FastAPI</span><span>Chart.js</span><span>SQLite</span><span>Railway</span><span>Resend</span>
        </div>
        <a href="https://www.silinkre.com/rate-tracker" target="_blank" class="project-link">
          View Live →
        </a>
      </div>
      <div class="project-visual">
        <div class="project-mockup">
          <div class="mockup-bar">
            <div class="mockup-dot"></div><div class="mockup-dot"></div><div class="mockup-dot"></div>
            <span style="margin-left:auto;font-size:.6rem;color:rgba(255,255,255,.5);font-family:'JetBrains Mono',monospace">silinkre.com/rate-tracker</span>
          </div>
          <div class="mockup-content" style="position:relative">
            <div style="display:flex;justify-content:space-between;align-items:center">
              <div class="mockup-line short" style="height:12px;background:rgba(255,255,255,.15)"></div>
              <div style="display:flex;gap:4px">
                <div style="width:40px;height:18px;border-radius:4px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.1)"></div>
                <div style="width:40px;height:18px;border-radius:4px;background:rgba(255,255,255,.15)"></div>
              </div>
            </div>
